{
  "entities": {
    "User": {
      "title": "User",
      "description": "Membro, Pastor, Tesoureiro ou Mídia",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "birthDate": { "type": "string" },
        "isConfirmedMember": { "type": "boolean" },
        "password": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "member", "media", "treasurer"] },
        "churchId": { "type": "string" },
        "streak": { "type": "number", "description": "Dias seguidos de devocional" },
        "totalDevotionals": { "type": "number", "description": "Total histórico" },
        "monthlyDevotionals": { "type": "number", "description": "Total no mês atual" },
        "lastDevotionalDate": { "type": "string", "format": "date" },
        "stars": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "phone", "password", "role", "churchId"]
    },
    "Church": {
      "title": "Church",
      "description": "Dados institucionais e visuais da igreja",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "pastorName": { "type": "string" },
        "address": { "type": "string" },
        "pixKey": { "type": "string" },
        "pixBeneficiary": { "type": "string", "description": "Nome do favorecido da chave PIX" },
        "bio": { "type": "string" },
        "logoUrl": { "type": "string" },
        "primaryColor": { "type": "string" },
        "secondaryColor": { "type": "string" },
        "accentColor": { "type": "string" },
        "fixedCostsGoal": { "type": "number" },
        "initialBalance": { "type": "number" },
        "fixedExpenses": { 
          "type": "array", 
          "items": { 
            "type": "object",
            "properties": {
              "category": { "type": "string" },
              "amount": { "type": "number" },
              "startDate": { "type": "string", "format": "date", "description": "YYYY-MM-DD" },
              "installments": { "type": "number", "description": "0 para fixo contínuo, > 0 para parcelado" }
            }
          }
        }
      },
      "required": ["id", "name"]
    },
    "DevotionalLog": {
      "title": "DevotionalLog",
      "description": "Log de devocional realizado por um membro",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "timestamp"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Controle de frequência de cultos",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "eventId": { "type": "string" },
        "totalPeople": { "type": "number" },
        "hasVisitors": { "type": "boolean" },
        "visitorCount": { "type": "number" },
        "childrenCount": { "type": "number" },
        "confirmed": { "type": "boolean" },
        "date": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "eventId", "totalPeople", "date"]
    },
    "Transaction": {
      "title": "Transaction",
      "description": "Lançamento financeiro",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "churchId": { "type": "string" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "amount": { "type": "number" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "createdBy": { "type": "string" }
      },
      "required": ["id", "churchId", "type", "amount", "date"]
    },
    "Event": {
      "title": "Event",
      "description": "Evento na agenda",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "churchId": { "type": "string" },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "date": { "type": "string", "format": "date-time" },
        "location": { "type": "string" },
        "imageUrl": { "type": "string" }
      },
      "required": ["id", "churchId", "title", "date"]
    }
  },
  "firestore": {
    "/churches/{churchId}": {
      "schema": "Church",
      "description": "Dados da igreja"
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "Perfis de usuários"
    },
    "/churches/{churchId}/transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Histórico financeiro"
    },
    "/churches/{churchId}/events/{eventId}": {
      "schema": "Event",
      "description": "Agenda de eventos"
    }
    "/churches/{churchId}/attendance/{attendanceId}": {
      "schema": "Attendance",
      "description": "Controle de frequência"
    },
    "/churches/{churchId}/devotionalLogs/{logId}": {
      "schema": "DevotionalLog",
      "description": "Histórico de devocionais dos membros"
    }
  }
}
